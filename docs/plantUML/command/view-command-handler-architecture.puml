@startuml
!include ../style.puml
skinparam arrowThickness 1.1
skinparam classAttributeIconSize 0
hide circle

class ViewCommandHandler LOGIC_COLOR {
  + handleListTasks(cmd: ParsedCommand): void
  + handleFind(cmd: ParsedCommand): void
  - listTasksForSku(skuId: String): void
  - listTasksByPriority(priorityStr: String): void
  - listTasksByDistance(locationStr: String): void
  - searchTasks(skuFilter: String, descFilter: String, taskIndex: int): List<String>
  - formatDistanceEntries(tasks: List<SKUTask>, locationStr: String): List<String>
}

class SKUList MODEL_COLOR {
  + findByID(skuID: String): SKU
  + getSKUList(): List<SKU>
}

class SKU MODEL_COLOR_T1 {
  + getSKUID(): String
  + getSKUTaskList(): SKUTaskList
}

class SKUTaskList MODEL_COLOR_T2 {
  + getSKUTaskList(): ArrayList<SKUTask>
  + isEmpty(): boolean
}

class ViewSKUTask LOGIC_COLOR_T1 {
  + listTasks(skuList: SKUList): List<SKUTask>
  + calculateDistance(task: SKUTask, location: String, skuList: SKUList): int
}

ViewCommandHandler -down-> "1" SKUList : skuList
SKUList -down-> "*" SKU : skuList
SKU -down-> "1" SKUTaskList : skuTaskList
ViewCommandHandler ..> ViewSKUTask : uses
@enduml

@startuml
!include ../style.puml

Participant ":SkuCommandHandler" as handler LOGIC_COLOR
Participant ":CommandHelper" as helper LOGIC_COLOR
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKU" as sku MODEL_COLOR_T1
Participant ":Ui" as ui UI_COLOR

handler -> helper ++ : findSkuOrError(skuList, "WIDGET-A1")
helper -> skuList ++ : findByID("WIDGET-A1")
skuList --> helper -- : sku

alt sku == null
  helper -> ui : printError("SKU not found: WIDGET-A1")
  helper --> handler : null
else sku found
  helper --> handler : sku
end
deactivate helper
@enduml

@startuml
!include ../style.puml

Actor User as user USER_COLOR
Participant ":Ui" as ui UI_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":TaskCommandHandler" as handler LOGIC_COLOR
Participant ":CommandHelper" as helper LOGIC_COLOR
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKU" as sku MODEL_COLOR_T1
Participant ":SKUTaskList" as taskList MODEL_COLOR_T2

user -> ui ++ : "addskutask n/PALLET-A d/2024-12-31 p/HIGH t/Check stock"
ui -> parser ++ : parse(...)
return cmd : ParsedCommand

ui -> runner ++ : run(cmd)
runner -> handler ++ : handleAddSkuTask(cmd)

handler -> skuList ++ : findByID("PALLET-A")
return sku

handler -> helper ++ : parsePriorityOrDefault(cmd)
return HIGH

handler -> sku ++ : getSKUTaskList()
return taskList

handler -> taskList ++ : addSKUTask("PALLET-A", HIGH, "2024-12-31", "Check stock")
return

handler -> taskList ++ : getSize()
return 1

return
return
return display success message
@enduml

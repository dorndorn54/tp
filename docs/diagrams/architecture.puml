@startuml Architecture
skinparam shadowing false
skinparam monochrome true
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam nodesep 50
skinparam ranksep 40
skinparam packagePadding 20

package "UI Layer" {
    rectangle "Ui" as Ui
    rectangle "ItemTasker" as App
    rectangle "Parser" as Parser
}

package "Logic Layer" {
    rectangle "CommandRunner" as CR
    rectangle "SKUCommandHandler" as SCH
    rectangle "TaskCommandHandler" as TCH
    rectangle "ViewCommandHandler" as VCH
}

package "Storage Layer" {
    rectangle "Storage" as Storage
    rectangle "Export" as Export
}

package "SKU Model" {
    rectangle "SKUList" as Model
}

App -left-> Ui
App -right-> Parser
App -down-> CR

CR -down-> SCH
CR -down-> TCH
CR -down-> VCH

CR -right-> Storage
CR ..> Export

SCH -down-> Model
TCH -down-> Model
VCH -down-> Model

Storage ..> Model
Export ..> Model

@enduml
